# NordIQ environment variables
# Copy to .env and fill in real values before running locally or in production.
#
# Generate a Fernet encryption key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# --- Database ---
DATABASE_URL=postgresql+asyncpg://nordiq:password@localhost:5432/nordiq
SYNC_DATABASE_URL=postgresql://nordiq:password@localhost:5432/nordiq
POSTGRES_PASSWORD=password   # used by docker-compose.prod.yml

# --- Security ---
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
ENCRYPTION_KEY=change-this-to-a-32-byte-fernet-key-base64-encoded
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Snowflake (optional — only needed if using Snowflake ingestor) ---
# SNOWFLAKE_ACCOUNT=your_account
# SNOWFLAKE_USER=your_user
# SNOWFLAKE_PASSWORD=your_password
# SNOWFLAKE_WAREHOUSE=your_warehouse
# SNOWFLAKE_DATABASE=your_database
# SNOWFLAKE_SCHEMA=your_schema

# --- Email notifications ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=notifications@nordiq.example.com
SMTP_TLS=false
# For production (e.g. SendGrid):
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.your_sendgrid_api_key
# SMTP_TLS=true

# --- Storage (for generated report CSV files) ---
REPORT_OUTPUT_DIR=./reports

# --- App ---
APP_ENV=development
LOG_LEVEL=info
FRONTEND_URL=http://localhost:8501
API_URL=http://localhost:8000
UVICORN_WORKERS=1
